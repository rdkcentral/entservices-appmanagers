autostart = "@PLUGIN_RDKAMSERVICE_AUTOSTART@"
precondition = ["Platform"]
callsign = "org.rdk.RDKAMService"
startuporder = "@PLUGIN_RDKAMSERVICE_STARTUPORDER@"

configuration = JSON()

root = JSON()
root.add("mode", "@PLUGIN_RDKAMSERVICE_MODE@")
root.add("locator", "lib@PLUGIN_IMPLEMENTATION@.so")
configuration.add("root", root)